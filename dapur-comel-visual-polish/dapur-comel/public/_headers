# Netlify _headers file (alternative to netlify.toml headers)
# This file is also respected by some other static hosts.

# Service worker — critical: never cache
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

/workbox-*.js
  Cache-Control: no-cache, no-store, must-revalidate

# PWA manifest
/manifest.webmanifest
  Cache-Control: no-cache

# Long cache for content-hashed assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/icons/*
  Cache-Control: public, max-age=86400

# Security on everything
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
